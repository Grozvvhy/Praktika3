<Window x:Class="AgroChem.OperatorClient.BatchProgramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Программа партии" Height="650" Width="950" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="16" FontWeight="Bold" Text="{Binding Title}" Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Список шагов -->
            <ListBox x:Name="listSteps" Grid.Column="0" Margin="0,0,10,0" SelectionChanged="ListSteps_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="0,0,0,1" BorderBrush="LightGray" Padding="5">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" Text="{Binding StepName}"/>
                                <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{Binding StatusColor}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Детали шага -->
            <Border Grid.Column="1" BorderBrush="#CCC" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock FontWeight="Bold" Text="Инструкция:"/>
                    <TextBox x:Name="txtInstruction" IsReadOnly="True" TextWrapping="Wrap" Height="60" Margin="0,5"/>

                    <TextBlock FontWeight="Bold" Text="Плановые параметры:" Margin="0,10,0,0"/>
                    <Grid Margin="0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Температура:"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtPlanTemp"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Давление:"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtPlanPressure"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Длительность (мин):"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtPlanDuration"/>
                    </Grid>

                    <TextBlock FontWeight="Bold" Text="Фактические значения:" Margin="0,15,0,0"/>
                    <Grid Margin="0,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Температура:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtActualTemp"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Давление:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtActualPressure"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Длительность (мин):"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtActualDuration"/>
                    </Grid>

                    <TextBlock FontWeight="Bold" Text="Комментарий:" Margin="0,15,0,0"/>
                    <TextBox x:Name="txtComment" Height="60" TextWrapping="Wrap" Margin="0,5"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button x:Name="btnStartStep" Content="Начать шаг" Width="120" Height="35" Margin="5" Click="BtnStartStep_Click" Background="#3498DB" Foreground="White"/>
                        <Button x:Name="btnCompleteStep" Content="Завершить шаг" Width="120" Height="35" Margin="5" Click="BtnCompleteStep_Click" Background="#27AE60" Foreground="White" IsEnabled="False"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Панель телеметрии -->
            <Border Grid.Column="2" BorderBrush="#CCC" BorderThickness="1" Padding="10" Margin="10,0,0,0">
                <StackPanel>
                    <TextBlock FontWeight="Bold" Text="📡 Телеметрия экструдера" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Температура:"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtTeleTemp" FontWeight="Bold"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Давление:"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtTelePressure" FontWeight="Bold"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Скорость шнека:"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtTeleSpeed" FontWeight="Bold"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Обновлено:"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtTeleLastUpdate" FontSize="10"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Закрыть" Width="100" Height="35" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>