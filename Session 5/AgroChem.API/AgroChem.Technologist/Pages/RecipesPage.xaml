<Page x:Class="AgroChem.Technologist.Pages.RecipesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Рецептуры">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="DataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" Grid.Row="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="150"/>
                <DataGridTextColumn Header="Версия" Binding="{Binding Version}" Width="80"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Обновить" Click="OnRefresh" Width="90" Margin="2"/>
            <Button Content="Создать" Click="OnCreate" Width="90" Margin="2"/>
            <Button Content="Открыть" Click="OnOpen" Width="90" Margin="2"/>
        </StackPanel>
    </Grid>
</Page>