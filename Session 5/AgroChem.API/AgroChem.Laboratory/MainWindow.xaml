<Window x:Class="AgroChem.Laboratory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лаборатория" Height="500" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <RadioButton x:Name="rbRaw" Content="Сырьё" IsChecked="True" Margin="5" Checked="Tab_Checked"/>
            <RadioButton x:Name="rbFinal" Content="Готовая продукция" Margin="5" Checked="Tab_Checked"/>
            <TextBlock x:Name="txtAnalyst" Margin="30,5,0,0" FontWeight="Bold"/>
        </StackPanel>

        <ListBox x:Name="listBatches" Grid.Row="1" Margin="10" SelectionChanged="ListBatches_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="0,0,0,1" BorderBrush="LightGray" Padding="5">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="{Binding DisplayName}"/>
                            <TextBlock Text="{Binding Info}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="btnQuality" Content="Контроль качества" Width="140" Height="35" Margin="5" Click="BtnQuality_Click" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>