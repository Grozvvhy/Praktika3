<Window x:Class="AgroChem.TechnologistClient.Windows.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" 
        Height="500" 
        Width="400" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Text="Регистрация нового пользователя" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

            <TextBlock Text="Логин:"/>
            <TextBox Name="txtUsername" Margin="0,5,0,10" Height="30"/>

            <TextBlock Text="Пароль:"/>
            <PasswordBox Name="txtPassword" Margin="0,5,0,10" Height="30"/>

            <TextBlock Text="ФИО:"/>
            <TextBox Name="txtFullName" Margin="0,5,0,10" Height="30"/>

            <TextBlock Text="Email:"/>
            <TextBox Name="txtEmail" Margin="0,5,0,10" Height="30"/>

            <TextBlock Text="Телефон:"/>
            <TextBox Name="txtPhone" Margin="0,5,0,10" Height="30"/>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                <Image Name="imgCaptcha" Width="150" Height="50" Stretch="Fill"/>
                <Button Name="btnRefreshCaptcha" Content="Обновить" Width="80" Margin="10,0,0,0"/>
            </StackPanel>

            <TextBox Name="txtCaptcha" Margin="0,5,0,10" Height="30"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button Name="btnRegister" Content="Зарегистрировать" Width="130" Height="35" Margin="0,0,10,0"/>
                <Button Name="btnCancel" Content="Отмена" Width="100" Height="35"/>
            </StackPanel>

            <TextBlock Name="txtError" Foreground="Red" Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Window>