<UserControl x:Class="AgroChem.TechnologistClient.Controls.OrdersControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <DataGrid Name="dgOrders" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№ заказа" Binding="{Binding OrderNumber}" Width="100"/>
                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="200"/>
                <DataGridTextColumn Header="План, кг" Binding="{Binding PlannedQuantityKg}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Дата старта" Binding="{Binding PlannedStartDate,StringFormat='dd.MM.yyyy'}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>