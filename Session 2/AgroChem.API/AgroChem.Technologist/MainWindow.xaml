<Window x:Class="AgroChem.Technologist.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Модуль технолога" Height="700" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Menu>
            <MenuItem Header="Рецептуры" Click="OnRecipesClick"/>
            <MenuItem Header="Техкарты" Click="OnCardsClick"/>
            <MenuItem Header="Партии" Click="OnBatchesClick"/>
            <MenuItem Header="Лаборатория" Click="OnLabClick"/>
        </Menu>
        <Frame x:Name="MainFrame" Grid.Row="1"/>
    </Grid>
</Window>