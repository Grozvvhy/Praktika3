<Window x:Class="AgroChem.Technologist.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="200" Width="300" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Логин" Grid.Row="0" Margin="0,5" />
        <TextBox x:Name="LoginBox" Grid.Row="1" Margin="0,5" />
        <TextBlock Text="Пароль" Grid.Row="2" Margin="0,5" />
        <PasswordBox x:Name="PasswordBox" Grid.Row="3" Margin="0,5" />
        <Button Content="Войти" Grid.Row="4" Margin="0,15" Click="OnLoginClick" />
    </Grid>
</Window>