<Window x:Class="AgroChem.Technologist.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Модуль технолога" FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Логин" Margin="0,5,0,0"/>
            <TextBox x:Name="LoginBox" Margin="0,0,0,10"/>

            <TextBlock Text="Пароль" Margin="0,5,0,0"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10"/>

            <StackPanel x:Name="RegPanel" Visibility="Collapsed">
                <TextBlock Text="Полное имя" Margin="0,5,0,0"/>
                <TextBox x:Name="FullNameBox" Margin="0,0,0,10"/>
                <TextBlock Text="Роль" Margin="0,5,0,0"/>
                <ComboBox x:Name="RoleCombo" DisplayMemberPath="Name"
                          SelectedValuePath="Id" Margin="0,0,0,10"/>
            </StackPanel>

            <TextBlock Text="Капча" Margin="0,10,0,5"/>
            <Image x:Name="CaptchaImage" Height="60" Width="180" HorizontalAlignment="Center"/>
            <Button Content="Обновить капчу" Click="OnRefreshCaptcha" FontSize="12"
                    HorizontalAlignment="Center" Margin="0,2,0,5"/>
            <TextBox x:Name="CaptchaBox" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="LoginBtn" Content="Войти" Width="120" Height="30"
                        Click="OnLoginClick" Margin="5,0"/>
                <Button x:Name="RegisterBtn" Content="Регистрация" Width="120" Height="30"
                        Click="OnRegisterClick" Margin="5,0"/>
            </StackPanel>

            <TextBlock x:Name="ErrorText" Foreground="Red" Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>