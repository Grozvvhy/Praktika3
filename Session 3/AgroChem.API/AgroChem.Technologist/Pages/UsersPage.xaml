<Page x:Class="AgroChem.Technologist.Pages.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Пользователи">
    <Grid>
        <DataGrid x:Name="DataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="150"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="100"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="100"/>
                <DataGridCheckBoxColumn Header="Архив" Binding="{Binding IsArchived}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>