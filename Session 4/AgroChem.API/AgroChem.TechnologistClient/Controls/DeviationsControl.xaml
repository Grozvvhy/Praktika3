<UserControl x:Class="AgroChem.TechnologistClient.Controls.DeviationsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <DataGrid Name="dgDeviations" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Партия" Binding="{Binding BatchNumber}" Width="100"/>
                <DataGridTextColumn Header="Время" Binding="{Binding EventTime,StringFormat='dd.MM.yyyy HH:mm'}" Width="130"/>
                <DataGridTextColumn Header="Тип" Binding="{Binding EventType}" Width="120"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="250"/>
                <DataGridTextColumn Header="Серьёзность" Binding="{Binding Severity}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>