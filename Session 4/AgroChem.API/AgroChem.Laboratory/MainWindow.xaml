<Window x:Class="AgroChem.Laboratory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лаборатория" Height="500" Width="800" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <RadioButton x:Name="rbRaw" Content="Сырьё" IsChecked="True" Margin="5" Checked="rbRaw_Checked"/>
            <RadioButton x:Name="rbFinal" Content="Готовая продукция" Margin="5" Checked="rbFinal_Checked"/>
            <TextBlock x:Name="lblAnalyst" Margin="20,5,0,0" FontWeight="Bold"/>
        </StackPanel>

        <ListBox x:Name="listRaw" Margin="10" SelectionChanged="list_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="{Binding BatchNumber}"/>
                            <TextBlock Text="{Binding MaterialName}"/>
                            <TextBlock Text="{Binding QuantityKg, StringFormat={}{0} кг}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ListBox x:Name="listFinal" Margin="10" Visibility="Collapsed" SelectionChanged="list_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="{Binding BatchNumber}"/>
                            <TextBlock Text="{Binding ProductName}"/>
                            <TextBlock Text="{Binding ActualQuantityKg, StringFormat={}{0} кг}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="btnHistory" Content="История" Width="100" Margin="5" Click="btnHistory_Click" IsEnabled="False"/>
            <Button x:Name="btnQuality" Content="Контроль качества" Width="140" Margin="5" Click="btnQuality_Click" IsEnabled="False"/>
        </StackPanel>
    </DockPanel>
</Window>